---
/**
 * MetaTags — Open Graph & Twitter Card meta tags for social sharing.
 *
 * Provides rich link previews on Discord, Twitter/X, LinkedIn, Slack, Facebook, etc.
 * Falls back to SITE-wide defaults when page-specific props aren't provided.
 */
import { getSite } from "../consts";

export interface Props {
  /** Page title. Used for og:title, twitter:title, and the <title> element. */
  title: string;
  /** Override title for meta tags only (leaves <title> untouched if you set it elsewhere). */
  meta_title?: string;
  /** Meta description. Falls back to SITE.description. */
  meta_description?: string;
  /** Full URL to the OG image. Falls back to /assets/images/196x196.png. */
  image?: string;
  /** Content type. `website` (default) or `article`. */
  og_type?: "website" | "article";
  /** Twitter card style. `summary_large_image` (default) gives a bigger preview. */
  twitter_card?: "summary" | "summary_large_image" | "app" | "player";
  /** Page author name. */
  author?: string;
  /** Locale. */
  lang?: string;
}


const {
  title,
  meta_title,
  meta_description,
  image = "/assets/images/196x196.png",
  og_type = "website",
  twitter_card = "summary_large_image",
  author,
  lang = "de",
} = Astro.props;

export const ogLocales: Record<string, string> = {
  de: "de_DE",
  en: "en_US",
};

const SITE = getSite(lang);

const displayTitle = meta_title || title;
const description = meta_description || SITE.description;
const pageUrl = new URL(Astro.url.pathname, SITE.url).href;

// Derive MIME type from image file extension for og:image:type
function imageMimeType(path: string): string {
  const ext = path.split('.').pop()?.toLowerCase() ?? '';
  const types: Record<string, string> = {
    png: 'image/png',
    jpg: 'image/jpeg',
    jpeg: 'image/jpeg',
    webp: 'image/webp',
    svg: 'image/svg+xml',
    gif: 'image/gif',
  };
  return types[ext] || 'image/png';
}

const ogImageUrl = image;
const ogImageType = image ? imageMimeType(image) : null;
const ogLocale = ogLocales[lang] || "de_DE";
---

<!-- Primary meta -->
<meta name="description" content={description} />
<meta name="author" content={author || SITE.title} />

<!-- Open Graph (Facebook, LinkedIn, Discord, Slack, etc.) -->
<meta property="og:site_name" content={SITE.title} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:url" content={pageUrl} />
<meta property="og:type" content={og_type} />
<meta property="og:title" content={displayTitle} />
<meta property="og:description" content={description} />
{
  image && ogImageUrl && (
    <>
      <meta property="og:image" content={ogImageUrl} />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
      {ogImageType && <meta property="og:image:type" content={ogImageType} />}
      <meta property="og:image:alt" content={`${displayTitle} — ${SITE.title}`} />
    </>
  )
}

<!-- Twitter Card -->
<meta name="twitter:card" content={twitter_card} />
<meta name="twitter:site" content={`@${SITE.twitter}`} />
<meta name="twitter:creator" content={`@${SITE.twitter}`} />
<meta name="twitter:title" content={displayTitle} />
<meta name="twitter:description" content={description} />
{
  image && ogImageUrl && (
    <meta name="twitter:image" content={ogImageUrl} />
  )
}
