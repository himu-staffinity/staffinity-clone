<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg"
     width="310" height="310"
     viewBox="0 0 310 310">

  <!-- scale around center (155,155) -->
  <g transform="translate(155 155) scale(1.3) translate(-155 -155)">
    <g fill="none"
       stroke="#66FBF0"
       stroke-width="1.5"
       stroke-linecap="round"
       stroke-linejoin="round">

      <!-- AI chip body -->
      <rect x="55" y="55" width="200" height="200" rx="28" ry="28"/>

      <!-- Chip pins (top) -->
      <line x1="95" y1="40" x2="95" y2="55"/>
      <line x1="135" y1="40" x2="135" y2="55"/>
      <line x1="175" y1="40" x2="175" y2="55"/>
      <line x1="215" y1="40" x2="215" y2="55"/>

      <!-- Chip pins (bottom) -->
      <line x1="95" y1="255" x2="95" y2="270"/>
      <line x1="135" y1="255" x2="135" y2="270"/>
      <line x1="175" y1="255" x2="175" y2="270"/>
      <line x1="215" y1="255" x2="215" y2="270"/>

      <!-- Chip pins (left) -->
      <line x1="40" y1="95" x2="55" y2="95"/>
      <line x1="40" y1="135" x2="55" y2="135"/>
      <line x1="40" y1="175" x2="55" y2="175"/>
      <line x1="40" y1="215" x2="55" y2="215"/>

      <!-- Chip pins (right) -->
      <line x1="255" y1="95" x2="270" y2="95"/>
      <line x1="255" y1="135" x2="270" y2="135"/>
      <line x1="255" y1="175" x2="270" y2="175"/>
      <line x1="255" y1="215" x2="270" y2="215"/>

      <!-- Neural network connections -->
      <line x1="105" y1="110" x2="155" y2="95"/>
      <line x1="105" y1="110" x2="155" y2="135"/>
      <line x1="105" y1="110" x2="155" y2="175"/>

      <line x1="105" y1="155" x2="155" y2="95"/>
      <line x1="105" y1="155" x2="155" y2="135"/>
      <line x1="105" y1="155" x2="155" y2="175"/>
      <line x1="105" y1="155" x2="155" y2="215"/>

      <line x1="105" y1="200" x2="155" y2="135"/>
      <line x1="105" y1="200" x2="155" y2="175"/>
      <line x1="105" y1="200" x2="155" y2="215"/>

      <line x1="155" y1="95" x2="205" y2="110"/>
      <line x1="155" y1="95" x2="205" y2="155"/>

      <line x1="155" y1="135" x2="205" y2="110"/>
      <line x1="155" y1="135" x2="205" y2="155"/>
      <line x1="155" y1="135" x2="205" y2="200"/>

      <line x1="155" y1="175" x2="205" y2="110"/>
      <line x1="155" y1="175" x2="205" y2="155"/>
      <line x1="155" y1="175" x2="205" y2="200"/>

      <line x1="155" y1="215" x2="205" y2="155"/>
      <line x1="155" y1="215" x2="205" y2="200"/>

      <!-- Nodes -->
      <circle cx="105" cy="110" r="5"/>
      <circle cx="105" cy="155" r="5"/>
      <circle cx="105" cy="200" r="5"/>

      <circle cx="155" cy="95" r="5"/>
      <circle cx="155" cy="135" r="5"/>
      <circle cx="155" cy="175" r="5"/>
      <circle cx="155" cy="215" r="5"/>

      <circle cx="205" cy="110" r="5"/>
      <circle cx="205" cy="155" r="5"/>
      <circle cx="205" cy="200" r="5"/>
    </g>
  </g>
</svg>
