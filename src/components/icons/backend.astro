      <rect x="95" y="140" width="120" height="35" rx="7"/>
      <rect x="95" y="195" width="120" height="35" rx="7"/>

      <!-- Status LEDs -->
      <circle cx="108" cy="103" r="4"/>
      <circle cx="108" cy="158" r="4"/>
      <circle cx="108" cy="213" r="4"/>

      <!-- Indicator lines -->
