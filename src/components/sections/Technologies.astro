---
import SectionDivider from "../SectionDivider.astro";
import * as Icons from "../icons";
import { Previous, Next } from "../icons";
// Solutions are passed as a prop (from content collection)
import type { CollectionEntry } from "astro:content";
import { defaultLang, getLangFromUrl } from "../../utils";
import { sections } from "../../content/structure/sections";

interface Props {
  number?: boolean;
  solutions: CollectionEntry<"solutions">[];
}

const { number, solutions } = Astro.props as Props;
const lang = getLangFromUrl(Astro.url);
const sectionsData = sections[lang];

function toPascalCase(str: string): string {
  return str
    .split("_")
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join("");
}

const solutionsWithIcons = solutions.map((s) => ({
  ...s,
  Icon: (Icons as Record<string, any>)[toPascalCase(s.data.icon)],
}));

function getUrl(solution: CollectionEntry<"solutions">) {
  const locale = lang === defaultLang ? "" : `/${lang}`;
  const id = solution.id.replace(`${lang}/`, "");
  return `${locale}/solutions/${id}`;
}
---

<div class="section-wrapper tech">
  <video autoplay muted playsinline loop>
    <source src="/assets/tech_video.mp4" type="video/mp4" />
  </video>
  <section id="technologies" class="divided-section">
    <div class="console">
      <h3>{number ? "01 | " : ""}<span class="scramble">{sectionsData.technologies}</span></h3>
      <div class="carousel">
        <div class="carousel-items">
          {solutionsWithIcons.map((solution) => (
            <div class="card">
              <a href={getUrl(solution)}>
                <div class="icon">
                  {solution.Icon && <solution.Icon />}
                </div>
                <h4>{solution.data.title}</h4>
                <ul>
                  {solution.data.subtitle.map((item: string) => (
                    <li class="carousel-subtitle">{item.trim()}</li>
                  ))}
                </ul>
                <div class="link-icon">
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
      <div class="carousel-btn prev"><Previous /></div>
      <div class="carousel-btn next"><Next /></div>
    </div>
    {number ? <SectionDivider nextsection="sectors" /> : null}
  </section>
</div>

<script>
  const track = document.querySelector(".carousel-items") as HTMLDivElement;
  const slides = Array.from(track?.children ?? []);
  const prevButton = document.querySelector(".carousel-btn.prev");
  const nextButton = document.querySelector(".carousel-btn.next");
  let currentSlideIndex = 0;

  const updateCarouselPosition = () => {
    const screenWidth = window.innerWidth;
    let visibleSlides = 5;
    if (screenWidth <= 480) {
      visibleSlides = 1;
    } else if (screenWidth <= 768) {
      visibleSlides = 2;
    }
    const slideWidth = slides[0].getBoundingClientRect().width + 10;
    if (track)     track.style.transform = `translateX(-${currentSlideIndex * slideWidth}px)`;
  };

  const changeSlide = (direction: 1 | -1) => {
    const screenWidth = window.innerWidth;
    let visibleSlides = 5;
    if (screenWidth <= 480) {
      visibleSlides = 1;
    } else if (screenWidth <= 768) {
      visibleSlides = 2;
    }
    const maxIndex = Math.max(slides.length - visibleSlides, 0);
    currentSlideIndex = Math.min(Math.max(currentSlideIndex + direction, 0), maxIndex);
    updateCarouselPosition();
  };

  nextButton?.addEventListener("click", () => changeSlide(1));
  prevButton?.addEventListener("click", () => changeSlide(-1));
  window.addEventListener("resize", updateCarouselPosition);
  updateCarouselPosition();
</script>
