---
import Button from "../Button.astro";
import SectionDivider from "../SectionDivider.astro";

interface Props {
  number?: boolean;
}

const { number } = Astro.props;
---

<div class="section-wrapper about">
  <video autoplay muted loop playsinline class="about-video">
    <source src="/assets/about.mp4" type="video/mp4" />
  </video>
  <section id="about" class="divided-section">
    <div class="console">
      <h3>{number ? "04 | " : ""}<span class="scramble">ABOUT</span></h3>
      <div class="text-content">
        <p>With bases in both India and Germany, we're mixing the best of two worlds: India's innovative drive combined with Germany's precision and quality standards.</p>
        <p>Good vibes and straight-up communication? That's how we roll — making sure every step we take is right on point with your vision by really listening to your ideas and needs.</p>
        <p>Curious? Let's connect, and you'll see how we can turn your goals into reality. Ready to shake things up together?</p>
        {number ? <Button content="More about us" link="/about" /> : null}
      </div>
    </div>
    {!number ? <SectionDivider nextsection="about-authors" /> : null}
  </section>
</div>
{!number ? (
  <section id="about-authors">
    <div class="console">
      <h3><span class="scramble">Authors</span></h3>
      <div class="author-wrapper">
        <slot name="authors" />
      </div>
    </div>
  </section>
) : null}
