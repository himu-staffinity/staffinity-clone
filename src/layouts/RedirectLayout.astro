---
export interface Props {
  redirect_to: string;
}

const { redirect_to } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting to...</title>
    <meta http-equiv="refresh" content={`0; url=${redirect_to}`} />
  </head>
  <body>
    Redirecting to...
  </body>
</html>
