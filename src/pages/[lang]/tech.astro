---
import PageLayout from "../../layouts/PageLayout.astro";
import Technologies from "../../components/sections/Technologies.astro";
import { getCollection } from "astro:content";
import { getLangFromUrl } from "../../utils";

// for exporting language based paths
export { getStaticPathsLang as getStaticPaths } from "../../utils";

const techContent = {
  en: {
    title: "Technologies",
    meta_title: "Technologies",
  },
  de: {
    title: "Technologien",
    meta_title: "Technologien",
  }
};

const lang = getLangFromUrl(Astro.url);

const { title, meta_title } = techContent[lang];

const solutions = await getCollection("solutions").then(s => s.filter(s => s.id.startsWith(`${lang}/`)));
---

<PageLayout title={title} meta_title={meta_title}>
  <Technologies solutions={solutions} />
</PageLayout>
