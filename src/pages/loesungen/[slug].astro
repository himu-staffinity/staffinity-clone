---
import { getCollection } from "astro:content";
import SolutionLayout from "../../layouts/SolutionLayout.astro";

export async function getStaticPaths() {
  const solutions = await getCollection("solutions");
  return solutions.map((solution) => ({
    params: { slug: solution.id.replace(/\.md$/, "") },
    props: { solution },
  }));
}

const { solution } = Astro.props;
const { data, body } = solution;
---

<SolutionLayout
  title={data.title}
  icon={data.icon}
  summary={data.summary || ""}
  primary_question={data.primary_question}
  primary_answer={data.primary_answer}
  details={data.details || []}
>
  {body && <div set:html={body} />}
</SolutionLayout>
