---
const env = import.meta.env;
const configPath = import.meta.env.DEV
  ? "/admin/config.dev.yml"
  : "/admin/config.yml";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link href={configPath} type="text/yaml" rel="cms-config-url" />
    <title>Staffinity DecapCMS</title>
  </head>
  <body>
  <script src="https://unpkg.com/decap-cms@3.3.3/dist/decap-cms.js"></script>
  </body>
</html>
